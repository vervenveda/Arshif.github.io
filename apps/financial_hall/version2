function money(n){return (isFinite(n)?n:0).toLocaleString(undefined,{style:'currency',currency:'USD',maximumFractionDigits:0});}
function num(id){return parseFloat($(id).value)||0;}
function calcBudget(){const income=num('bIncome'), total=num('bHousing')+num('bFood')+num('bTransport')+num('bDebt')+num('bOther'), left=income-total;$('bOut').innerHTML=`Planned expenses: <strong>${money(total)}</strong><br>Remaining / gap: <strong class="${left>=0?'status-ok':'status-warn'}">${money(left)}</strong>`;}
function calcEmergency(){const target=num('eEss')*num('eMonths'), gap=Math.max(0,target-num('eCurrent'));$('eOut').innerHTML=`Target: <strong>${money(target)}</strong><br>Remaining to target: <strong>${money(gap)}</strong>`;}
function calcCompound(){let bal=num('cStart'), monthly=num('cMonthly'), r=(num('cRate')/100)/12, months=num('cYears')*12; for(let i=0;i<months;i++){bal=bal*(1+r)+monthly;} $('cOut').innerHTML=`Estimated future value: <strong>${money(bal)}</strong><br><span class="muted">Hypothetical only; actual returns vary and can be negative.</span>`;}
function calcDebt(){let bal=num('dBal'), r=(num('dRate')/100)/12, pay=num('dPay'), months=0, interest=0; if(pay<=bal*r){$('dOut').innerHTML='<span class="status-warn">Payment may be too low to reduce the balance.</span>';return;} while(bal>0 && months<600){const int=bal*r;interest+=int;bal=bal+int-pay;months++;} $('dOut').innerHTML=`Estimated payoff: <strong>${months}</strong> months<br>Estimated interest: <strong>${money(interest)}</strong>`;}
function calcNet(){$('nOut').innerHTML=`Net worth snapshot: <strong>${money(num('nAssets')-num('nDebt'))}</strong><br><span class="muted">A snapshot for planning, not a measure of human value.</span>`;}
function calcBE(){const fixed=num('beFixed'), p=num('bePrice'), v=num('beVar'), margin=p-v; $('beOut').innerHTML= margin>0?`Break-even units/services: <strong>${Math.ceil(fixed/margin)}</strong><br>Contribution margin: <strong>${money(margin)}</strong>`:'<span class="status-warn">Price must exceed variable cost.</span>';}
function clamp(v,min,max){return Math.max(min,Math.min(max,v));}
function randNormal(){let u=0,v=0;while(u===0)u=Math.random();while(v===0)v=Math.random();return Math.sqrt(-2*Math.log(u))*Math.cos(2*Math.PI*v);}
function percentile(arr,p){return arr[Math.max(0,Math.min(arr.length-1,Math.floor((arr.length-1)*p)))];}
function runMonteCarlo(){
  const start=num('mcSavings'), income=num('mcIncome'), costs=num('mcCosts'), incomeVol=clamp(num('mcIncomeVol')/100,0,2), costVol=clamp(num('mcCostVol')/100,0,2), shockProb=clamp(num('mcShockProb')/100,0,1), shockCost=num('mcShockCost'), months=clamp(Math.round(num('mcMonths')||12),1,60), goal=num('mcGoal');
  const trials=500, endings=[]; let neverNegative=0, metGoal=0, shockRuns=0, depleted=0;
  for(let t=0;t<trials;t++){
    let cash=start, goalSaved=0, ok=true, hadShock=false;
    for(let m=0;m<months;m++){
      const inc=Math.max(0,income*(1+randNormal()*incomeVol));
      const exp=Math.max(0,costs*(1+randNormal()*costVol));
      cash += inc - exp;
      if(goal>0 && cash>=goal){cash -= goal; goalSaved += goal;}
      if(Math.random()<shockProb){hadShock=true; cash -= Math.max(0, shockCost*(0.45+Math.random()*1.45));}
      if(cash<0) ok=false;
    }
    endings.push(cash); if(ok) neverNegative++; if(goalSaved>=goal*months) metGoal++; if(hadShock) shockRuns++; if(cash<0) depleted++;
  }
  endings.sort((a,b)=>a-b); const avg=endings.reduce((a,b)=>a+b,0)/trials;
  const p10=percentile(endings,.10), p50=percentile(endings,.50), p90=percentile(endings,.90);
  const monthlyGap=income-costs-goal;
  $('mcOut').textContent = `MONTE CARLO FINANCIAL RESILIENCE PROCESSOR\nTrials: ${trials} randomized household runs · Months: ${months}\n\nBase monthly gap after goal: ${money(monthlyGap)}\nAverage ending cash: ${money(avg)}\n10th percentile ending cash: ${money(p10)}\nMedian ending cash: ${money(p50)}\n90th percentile ending cash: ${money(p90)}\nStayed cash-positive all months: ${Math.round(neverNegative/trials*100)}%\nMet saving/investing goal every month: ${Math.round(metGoal/trials*100)}%\nHad at least one shock: ${Math.round(shockRuns/trials*100)}%\nEnded below zero: ${Math.round(depleted/trials*100)}%\n\nStudy reflection: If cash-positive probability is low, test changes such as higher starting emergency savings, lower fixed costs, smaller goals, or insurance/benefits/community-resource planning. This simulation is educational only; it does not predict actual income, markets, emergencies, taxes, eligibility, or personal outcomes.`;
}
