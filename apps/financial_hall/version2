function gradeQuiz(id){const qz=QUIZZES.find(q=>q.moduleId===id);let correct=0;const review=[];qz.questions.forEach((q,i)=>{const v=document.querySelector(`input[name=q${i}]:checked`); const picked=v?Number(v.value):-1; const ok=picked===q.answer; if(ok) correct++; review.push(`<div class="panel" style="margin-bottom:10px"><h3>${i+1}. ${esc(q.q)}</h3><p><strong>Your answer:</strong> ${picked>=0?esc(q.options[picked]):'<span class="status-warn">No answer selected</span>'}</p><p><strong>Correct answer:</strong> ${esc(q.options[q.answer])}</p><p class="${ok?'status-ok':'status-warn'}">${ok?'Correct':'Review needed'}</p><p class="muted">${esc(q.explain||'Review the module resources and try again.')}</p></div>`);});const score=Math.round(correct/qz.questions.length*100);state.quizScores[id]=score; if(score>=80) state.completed[id]=true; save(); openModal('Quiz Result',`<h2>${score}%</h2><p class="${score>=80?'status-ok':'status-warn'}">${score>=80?'Mastery met. Module marked complete.':'Retake encouraged. Review the module resources and explanations, then try again.'}</p><button class="btn" onclick="AFH.takeQuiz('${id}')">Retake</button><h3>Answer Review</h3>${review.join('')}`); renderAssess(); renderCourse(); renderGate();}
