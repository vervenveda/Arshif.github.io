<title>ARSHIF Financial Hall — Certification Portal v2</title>
<style>
:root{color-scheme:dark;}
*{box-sizing:border-box}
body{margin:0;min-height:100vh;background:#050711;color:#f7f0df;font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;}
#arshif-financial-hall{--gold:#d9b878;--gold2:#b99252;--ink:#21170d;--obsidian:#090b14;--mid:#12172a;--panel:#171b2e;--soft:#f2e8d3;--muted:#c8bfae;--green:#9fc7a4;--red:#f0a6a6;--blue:#a8c7ff;--shadow:0 24px 70px rgba(0,0,0,.58);min-height:100vh;background:radial-gradient(circle at top left,#24233c 0,#090b14 44%,#03040a 100%);padding:24px;}
#arshif-financial-hall .afh-shell{max-width:1480px;margin:0 auto;border:1px solid rgba(217,184,120,.42);box-shadow:var(--shadow);border-radius:28px;overflow:hidden;background:linear-gradient(145deg,rgba(23,27,46,.96),rgba(7,9,18,.98));}
#arshif-financial-hall header{padding:34px 26px 28px;text-align:center;background:radial-gradient(circle at top,#2a2944,#101423 76%);border-bottom:1px solid rgba(247,240,223,.12);}
#arshif-financial-hall h1{margin:0;font-family:Georgia,"Times New Roman",serif;font-size:clamp(2rem,4vw,4.2rem);letter-spacing:.12em;text-transform:uppercase;color:#fff7e6;}
#arshif-financial-hall .tagline{margin:10px auto 0;color:var(--gold);letter-spacing:.18em;text-transform:uppercase;font-size:.8rem;font-weight:700;}
#arshif-financial-hall .sub{max-width:920px;margin:14px auto 0;line-height:1.75;color:var(--soft);font-size:1rem;}
#arshif-financial-hall .notice{max-width:1040px;margin:16px auto 0;border:1px solid rgba(217,184,120,.45);border-radius:18px;padding:12px 14px;background:rgba(0,0,0,.22);color:#fff3d5;line-height:1.55;font-size:.92rem;}
#arshif-financial-hall nav{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;padding:14px;background:#0c101e;border-bottom:1px solid rgba(247,240,223,.1);position:sticky;top:0;z-index:4;}
#arshif-financial-hall .tab{border:1px solid rgba(217,184,120,.28);background:rgba(255,255,255,.04);color:var(--soft);border-radius:999px;padding:9px 13px;cursor:pointer;font-weight:700;letter-spacing:.04em;}
#arshif-financial-hall .tab.active,#arshif-financial-hall .btn.primary{background:linear-gradient(135deg,var(--gold),var(--gold2));color:#1d1307;border-color:transparent;}
#arshif-financial-hall main{padding:20px;}
#arshif-financial-hall .view{display:none;}
#arshif-financial-hall .view.active{display:block;}
#arshif-financial-hall .grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:14px;}
#arshif-financial-hall .wide-grid{display:grid;grid-template-columns:1.2fr .8fr;gap:16px;}
#arshif-financial-hall .panel,.card{border:1px solid rgba(217,184,120,.24);background:linear-gradient(180deg,rgba(255,255,255,.055),rgba(255,255,255,.025));border-radius:22px;padding:16px;box-shadow:0 12px 30px rgba(0,0,0,.25);}
#arshif-financial-hall h2,#arshif-financial-hall h3{font-family:Georgia,"Times New Roman",serif;color:var(--gold);letter-spacing:.06em;}
#arshif-financial-hall h2{font-size:1.7rem;margin:0 0 12px;}
#arshif-financial-hall h3{margin:0 0 8px;font-size:1.15rem;}
#arshif-financial-hall p,#arshif-financial-hall li{color:var(--soft);line-height:1.65;}
#arshif-financial-hall .muted{color:var(--muted);font-size:.92rem;}
#arshif-financial-hall .badge,.chip{display:inline-flex;align-items:center;gap:5px;border:1px solid rgba(217,184,120,.38);color:var(--gold);border-radius:999px;padding:4px 9px;font-size:.74rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;background:rgba(0,0,0,.18);}
#arshif-financial-hall .chips{display:flex;flex-wrap:wrap;gap:7px;margin:12px 0;}
#arshif-financial-hall .chip{cursor:pointer;color:var(--soft);}
#arshif-financial-hall .chip.active{background:var(--gold);color:#1d1307;border-color:transparent;}
#arshif-financial-hall input,#arshif-financial-hall select,#arshif-financial-hall textarea{width:100%;border:1px solid rgba(217,184,120,.28);border-radius:14px;padding:10px 12px;background:#080b16;color:var(--soft);font:inherit;}
#arshif-financial-hall textarea{min-height:110px;resize:vertical;}
#arshif-financial-hall label{display:block;color:#fff2d1;font-weight:700;margin:10px 0 6px;font-size:.9rem;}
#arshif-financial-hall .controls{display:grid;grid-template-columns:1fr auto auto;gap:10px;align-items:end;margin-bottom:14px;}
#arshif-financial-hall .btn{border:1px solid rgba(217,184,120,.34);background:rgba(0,0,0,.22);color:var(--soft);border-radius:12px;padding:9px 12px;cursor:pointer;font-weight:800;}
#arshif-financial-hall .btn:hover,#arshif-financial-hall .tab:hover,#arshif-financial-hall .chip:hover{filter:brightness(1.13)}
#arshif-financial-hall .card{position:relative;overflow:hidden;}
#arshif-financial-hall .card:before{content:"";position:absolute;inset:0 0 auto 0;height:4px;background:linear-gradient(90deg,var(--gold),transparent);opacity:.75;}
#arshif-financial-hall .card-title{font-family:Georgia,"Times New Roman",serif;font-size:1.15rem;color:#fff5dd;margin:6px 0 8px;}
#arshif-financial-hall .card-meta{display:flex;flex-wrap:wrap;gap:6px;margin:8px 0;}
#arshif-financial-hall .row{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;}
#arshif-financial-hall .three{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;}
#arshif-financial-hall .progressbar{height:12px;border-radius:999px;background:#070a13;border:1px solid rgba(217,184,120,.25);overflow:hidden;}
#arshif-financial-hall .progressbar span{display:block;height:100%;background:linear-gradient(90deg,var(--gold2),var(--gold));width:0%;}
#arshif-financial-hall table{width:100%;border-collapse:collapse;color:var(--soft);font-size:.92rem;}
#arshif-financial-hall th,#arshif-financial-hall td{border-bottom:1px solid rgba(247,240,223,.1);padding:8px;text-align:left;vertical-align:top;}
#arshif-financial-hall th{color:var(--gold);}
#arshif-financial-hall .status-ok{color:var(--green);font-weight:800}
#arshif-financial-hall .status-warn{color:var(--red);font-weight:800}
#arshif-financial-hall .modal{display:none;position:fixed;inset:0;z-index:10;background:rgba(0,0,0,.55);padding:18px;}
#arshif-financial-hall .modal.show{display:block;}
#arshif-financial-hall .dossier{position:absolute;left:50%;top:56px;transform:translateX(-50%);width:min(920px,calc(100vw - 26px));max-height:calc(100vh - 90px);overflow:auto;border:1px solid rgba(217,184,120,.55);border-radius:24px;background:linear-gradient(145deg,#17192a,#080a14);box-shadow:0 30px 90px rgba(0,0,0,.78);}
#arshif-financial-hall .dossier-head{cursor:move;display:flex;justify-content:space-between;gap:14px;align-items:center;padding:14px 16px;background:rgba(217,184,120,.12);border-bottom:1px solid rgba(217,184,120,.24);position:sticky;top:0;z-index:1;}
#arshif-financial-hall .dossier-body{padding:16px;}
#arshif-financial-hall .close{border:0;background:#2a0f0f;color:#ffd9d9;border-radius:10px;padding:7px 10px;cursor:pointer;font-weight:900;}
#arshif-financial-hall .cert{background:#f8f0dd;color:#24170b;border:10px double #b99252;padding:34px;border-radius:18px;text-align:center;font-family:Georgia,"Times New Roman",serif;}
#arshif-financial-hall .cert h2{color:#2c1a08;font-size:2rem;}
#arshif-financial-hall .cert .name{font-size:2.4rem;border-bottom:2px solid #b99252;display:inline-block;padding:6px 28px;margin:16px;color:#1b1108;}
#arshif-financial-hall footer{text-align:center;padding:18px;color:var(--muted);border-top:1px solid rgba(247,240,223,.1);background:#080b16;}
@media(max-width:900px){#arshif-financial-hall{padding:10px}#arshif-financial-hall .wide-grid,#arshif-financial-hall .row,#arshif-financial-hall .three,#arshif-financial-hall .controls{grid-template-columns:1fr}#arshif-financial-hall nav{position:static}}
