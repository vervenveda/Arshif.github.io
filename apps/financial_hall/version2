function printReport(){const c=criteria(); const html=`<h1>ARSHIF Financial Hall Progress Report</h1><p><strong>Learner:</strong> ${esc(state.studentName||'Unnamed Learner')}</p><p><strong>Date:</strong> ${new Date().toLocaleDateString()}</p><p><strong>Modules:</strong> ${completedCount()}/${MODULES.length} · <strong>Quiz Average:</strong> ${avgQuiz()}% · <strong>Midterm:</strong> ${state.midterm??'—'}% · <strong>Final:</strong> ${state.final??'—'}%</p><h2>Completion Gate</h2><ul>${Object.entries(c).map(([k,v])=>`<li>${k}: ${v?'Complete':'Incomplete'}</li>`).join('')}</ul><h2>Module Record</h2><table border="1" cellspacing="0" cellpadding="5"><tr><th>Module</th><th>Complete</th><th>Quiz</th></tr>${MODULES.map(m=>`<tr><td>${esc(m.id+' — '+m.title)}</td><td>${state.completed[m.id]?'Yes':'No'}</td><td>${state.quizScores[m.id]??'—'}%</td></tr>`).join('')}</table><h2>Capstone Preview</h2><p>${esc((state.capstone||'').slice(0,1200))}</p>`; const w=window.open('','_blank'); w.document.write(`<!doctype html><title>Financial Hall Progress Report</title><style>body{font-family:system-ui;padding:24px;line-height:1.5}table{width:100%;border-collapse:collapse}td,th{border:1px solid #777;padding:5px;text-align:left}</style>${html}`); w.document.close(); w.print();}
function exportNotes(){const blob=new Blob([JSON.stringify({notes:state.notes,favorites:state.favorites,quizScores:state.quizScores,completed:state.completed,capstone:state.capstone},null,2)],{type:'application/json'}); const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='arshif-financial-hall-notes.json';a.click();URL.revokeObjectURL(a.href);}
function openModal(title,body){$('modalTitle').textContent=title;$('modalBody').innerHTML=body;$('modal').classList.add('show');}
function closeModal(){$('modal').classList.remove('show');}
function makeDraggable(){const modal=$('dossier'), handle=$('drag'); let down=false, sx=0, sy=0, ox=0, oy=0; handle.addEventListener('mousedown',e=>{if(e.target.closest('button,a,input,textarea,select,label')) return; down=true; const rect=modal.getBoundingClientRect(); modal.style.transform='none'; modal.style.left=rect.left+'px'; modal.style.top=rect.top+'px'; sx=e.clientX; sy=e.clientY; ox=rect.left; oy=rect.top; document.body.style.userSelect='none'; e.preventDefault();}); window.addEventListener('mousemove',e=>{if(!down)return; modal.style.left=Math.max(6,Math.min(window.innerWidth-80,ox+e.clientX-sx))+'px'; modal.style.top=Math.max(6,Math.min(window.innerHeight-60,oy+e.clientY-sy))+'px';}); window.addEventListener('mouseup',()=>{down=false;document.body.style.userSelect='';});}
function init(){initTabs();renderDashboard();renderCourse();renderAtlas();renderStudio();renderAssess();renderCapstone();renderSources();makeDraggable();}
window.AFH={showTab,filterModules,openModule,toggleComplete,markAllVisible,filterAtlas,setLevel,openDossier,toggleFav,saveNote,closeModal,calcBudget,calcEmergency,calcCompound,calcDebt,calcNet,calcBE,runMonteCarlo,takeQuiz,gradeQuiz,takeExam,gradeExam,saveCapstone,savePledge,renderCertificate,updateCertName,printCertificate,printReport,exportNotes};
init();
})();
