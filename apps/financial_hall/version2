const GLOSSARY = [["APR", "Annual percentage rate; an annualized measure of borrowing cost including certain fees."], ["Asset", "Something owned that has economic value."], ["Liability", "A debt or financial obligation."], ["Net worth", "Assets minus liabilities; a planning snapshot, not a measure of human value."], ["Budget", "A plan for income, expenses, saving, debt, and goals."], ["Emergency fund", "Savings set aside for urgent unexpected events or income shocks."], ["Credit report", "A record of credit accounts and payment history used by lenders and others."], ["Credit score", "A numerical estimate based on credit-report information."], ["Principal", "The amount borrowed or invested before interest."], ["Interest", "The cost of borrowing money or the earnings paid on savings/investments."], ["Compound interest", "Interest that earns interest over time."], ["Diversification", "Spreading exposure among investments to reduce concentration risk."], ["Inflation", "A general rise in prices that reduces purchasing power."], ["Liquidity", "How easily an asset can be converted to cash without major loss."], ["Deductible", "Amount paid before some insurance coverage begins."], ["Premium", "Regular amount paid for insurance coverage."], ["Fiduciary", "A person or firm with certain obligations to act in another’s best interest."], ["Conflict of interest", "A situation where incentives may influence judgment or recommendations."], ["Capstone", "A final project demonstrating integrated learning."], ["Certificate of Completion", "Recognition that portal requirements were completed; not a license or accredited credential."], ["Amortization", "A schedule showing how loan payments are split between interest and principal over time."], ["Asset allocation", "How money is divided among broad investment categories such as stocks, bonds, cash, or other assets."], ["Grace period", "A period when interest may not be charged if credit-card terms are met."], ["Sinking fund", "Savings set aside for a known future expense."], ["Fraud alert", "A notice on a credit report that asks creditors to verify identity before opening new credit."], ["Credit freeze", "A restriction that limits access to a credit report, making it harder for identity thieves to open accounts."], ["Total cost of ownership", "The full cost of an item over time, including purchase price, fees, maintenance, insurance, repairs, and financing."], ["Monte Carlo simulation", "A model that runs many randomized trials to show a range of possible outcomes, not a guarantee."]];
const STORE_KEY = 'arshifFinancialHall.v2';
const tabs = [
 ['dashboard','Dashboard'],['course','Course Path'],['atlas','Financial Atlas'],['studio','Money Studio'],['assess','Quizzes & Exams'],['capstone','Capstone'],['certificate','Certificate'],['sources','Source Vault']
];
let state = load();
function load(){try{return JSON.parse(localStorage.getItem(STORE_KEY))||defaultState();}catch(e){return defaultState();}}
function defaultState(){return {completed:{},quizScores:{},favorites:{},notes:{},midterm:null,final:null,capstone:'',pledge:false,studentName:'',portfolio:[],budget:null};}
function save(){localStorage.setItem(STORE_KEY,JSON.stringify(state)); renderDashboardMini();}
function $(id){return document.getElementById(id);}
function esc(s){return String(s??'').replace(/[&<>"']/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));}
function pct(n,d){return d?Math.round((n/d)*100):0;}
function avgQuiz(){const vals=Object.values(state.quizScores).map(Number);return vals.length?Math.round(vals.reduce((a,b)=>a+b,0)/vals.length):0;}
function completedCount(){return Object.keys(state.completed).filter(k=>state.completed[k]).length;}
function masteredQuizCount(){return MODULES.filter(m=>Number(state.quizScores[m.id]||0)>=80).length;}
function allModuleQuizzesMastered(){return masteredQuizCount()>=MODULES.length;}
function criteria(){return {modules:completedCount()>=MODULES.length,quizzes:allModuleQuizzesMastered(),midterm:(state.midterm||0)>=80,final:(state.final||0)>=80,capstone:(state.capstone||'').trim().length>=220,pledge:!!state.pledge};}
function ready(){return Object.values(criteria()).every(Boolean);}
function initTabs(){const nav=$('tabs');nav.innerHTML=tabs.map(([id,label])=>`<button class="tab ${id==='dashboard'?'active':''}" data-tab="${id}">${label}</button>`).join(''); nav.addEventListener('click',e=>{if(e.target.classList.contains('tab')) showTab(e.target.dataset.tab);});}
function showTab(id){document.querySelectorAll('#arshif-financial-hall .tab').forEach(b=>b.classList.toggle('active',b.dataset.tab===id));document.querySelectorAll('#arshif-financial-hall .view').forEach(v=>v.classList.remove('active'));$('view-'+id).classList.add('active'); if(id==='certificate')renderCertificate();}
function renderDashboardMini(){const bar=$('dashProgress'); if(bar) bar.style.width=pct(completedCount(),MODULES.length)+'%'; const stat=$('dashStats'); if(stat) stat.innerHTML=`<strong>${completedCount()}/${MODULES.length}</strong> modules · mastered quizzes <strong>${masteredQuizCount()}/${MODULES.length}</strong> · quiz avg <strong>${avgQuiz()}%</strong> · midterm <strong>${state.midterm??'—'}%</strong> · final <strong>${state.final??'—'}%</strong>`;}
function renderDashboard(){$('view-dashboard').innerHTML=`
 <div class="wide-grid">
  <div class="panel"><h2>Financial Stewardship Dashboard</h2><p>This hall walks learners through practical financial literacy, consumer protection, investing education, ethics, and portfolio evidence. Completion requires 80% mastery and a written capstone.</p><div class="progressbar"><span id="dashProgress"></span></div><p id="dashStats" class="muted"></p><div class="chips"><span class="badge">48 modules</span><span class="badge">${DOSSIERS.length} dossiers</span><span class="badge">80% mastery</span><span class="badge">Certificate of Completion</span></div><button class="btn primary" onclick="AFH.showTab('course')">Begin Course</button> <button class="btn" onclick="AFH.printReport()">Print Progress Report</button></div>
  <div class="panel"><h2>Completion Gate</h2><div id="gateBox"></div></div>
 </div>
 <div class="grid" style="margin-top:16px">
  <div class="card"><h3>Learning Arc</h3><p>Earn → spend wisely → save → borrow carefully → protect → invest with literacy → steward community resources.</p></div>
  <div class="card"><h3>Safety Frame</h3><p>Every module asks learners to verify sources, avoid pressure tactics, document choices, and know when qualified help is needed.</p></div>
  <div class="card"><h3>Portfolio Evidence</h3><p>Save budgets, calculations, reflections, source notes, capstone drafts, and progress reports for parent, advisor, or self-review.</p></div>
 </div>`; renderGate(); renderDashboardMini();}
